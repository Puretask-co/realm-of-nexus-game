        {
            "id": "half_abyss",
            "name": "Half-Abyss",
            "description": "Touched by the Abyss yet not consumed. Half-Abyss carry corruption in their veins but refuse to surrender to it, wielding their tainted heritage as both weapon and burden. Feared by many, understood by few.",
            "lore": "The Half-Abyss are living paradoxes — offspring of Verdance dwellers who were exposed to concentrated Abyss energy, or in rarer cases, the children of unions between mortals and Abyss-touched beings. They carry corruption in their blood, but through sheer will or some unknown quirk of spiritual genetics, they resist the madness that claims most who touch the void. The Bloomguard watches them with suspicion, the Emerald Coven studies them with fascination, and the common folk avoid them with fear. Half-Abyss constantly struggle against the whispers of the Abyss that echo in their minds, but this very struggle grants them extraordinary resilience. Their existence is only revealed to the player after Act 1, when the true scope of the Abyss threat becomes clear and certain... previously impossible unions come to light.",
            "attributeModifiers": [
                {
                    "attribute": "Resilience",
                    "value": 2,
                    "description": "+2 Resilience — their bodies are hardened by the constant internal battle against corruption"
                },
                {
                    "attribute": "Charisma",
                    "value": -1,
                    "description": "-1 Charisma — the visible signs of Abyss taint make social interactions more difficult"
                }
            ],
            "specialAbility": {
                "id": "abyssal_heritage",
                "name": "Abyssal Heritage",
                "description": "A suite of abilities born from the Half-Abyss's corrupted bloodline. Includes innate corruption resistance, immunity to the Corrupted status effect, and reduced criminality penalties when using Forbidden spells.",
                "abilities": [
                    {
                        "id": "corruption_resistance",
                        "name": "Corruption Resistance",
                        "description": "50% reduced effect from all corruption sources. The Abyss within recognizes and neutralizes external corruption.",
