                            "value": 0.50,
                            "passive": true
                        }
                    },
                    {
                        "id": "abyss_immunity",
                        "name": "Abyss Immunity",
                        "description": "Completely immune to the Corrupted status effect. Cannot be turned by Abyss corruption.",
                        "effect": {
                            "type": "status_immunity",
                            "target": "corrupted",
                            "passive": true
                        }
                    },
                    {
                        "id": "forbidden_affinity",
                        "name": "Forbidden Affinity",
                        "description": "Can use Forbidden spells with 10% reduced criminality penalty. The Abyss taint provides a natural affinity for dark magic.",
                        "effect": {
                            "type": "criminality_reduction",
                            "value": 0.10,
                            "appliesTo": "forbidden_spells"
                        }
                    }
                ],
                "passive": true
            },
