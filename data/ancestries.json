        {
            "id": "soulborn",
            "name": "Soulborn",
            "description": "Born from the Everwood's soul magic, Soulborn are rare beings with an innate connection to the Domain Soul Pool. They perceive the world through layers of spiritual resonance that others cannot fathom.",
            "lore": "Soulborn are not born of flesh and blood in the traditional sense. During Silver Sap phases, when the Everwood's magical energies reach their peak, the forest itself occasionally gives rise to new life — beings woven from concentrated soul energy and living wood. These rare individuals emerge fully formed from the roots of ancient trees, carrying memories that belong to no one and everyone. The Emerald Coven considers them sacred, living proof that the Domain Soul Pool is more than mere energy — it is a consciousness. Soulborn hear the Veil whisper in quiet moments and can sense disturbances in the spiritual fabric of Verdance before anyone else. Their connection to the DSP grants them a personal reserve larger than any other ancestry, making them natural conduits for the domain's power.",
            "attributeModifiers": [
                {
                    "attribute": "Charisma",
                    "value": 1,
                    "description": "+1 Charisma — their soul-touched presence draws others in"
                },
                {
                    "attribute": "Insight",
                    "value": 1,
                    "description": "+1 Insight — they perceive the spiritual undercurrents of the world"
                },
                {
                    "attribute": "dspMaxReserve",
                    "value": 5,
                    "description": "+5 to maximum personal DSP reserve, reflecting their deeper connection to the Domain Soul Pool"
                }
            ],
            "specialAbility": {
                "id": "soulborn_attunement",
                "name": "Soulborn Attunement",
                "description": "A suite of innate spiritual abilities granted by the Soulborn's unique origin. Includes Veil Sense (detect Veil disturbances naturally) and Silver Sap Affinity (+1 to all rolls during Silver Sap phase).",
                "abilities": [
